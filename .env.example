# Spuk environment — copy to .env and fill in ONLY if you enable the optional,
# PAID Claude post-processing in config.toml. The core dictation loop needs NONE
# of this and makes zero network calls.

# Optional Claude post-processing (Phase 4). Leave empty for the free local loop.
# Prefer reading this from the macOS Keychain in the real build; .env is for dev only.
ANTHROPIC_API_KEY=

# Where to cache downloaded Whisper models. Pointing this at the 2TB drive keeps
# the ~480MB "small" model off your internal disk.
HF_HOME=/Volumes/2TB/Claude/Spuk/models
